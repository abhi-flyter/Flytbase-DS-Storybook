{
  "name": "@flytbase/design-system",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "Flytbase React design system components, tokens, and Storybook documentation.",
  "main": "./dist/flytbase-design-system.umd.cjs",
  "module": "./dist/flytbase-design-system.js",
  "types": "./dist/index.d.ts",
  "style": "./src/style.css",
  "files": [
    "dist",
    "src/style.css",
    "src/components/styles.css",
    "tokens",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/flytbase-design-system.js",
      "require": "./dist/flytbase-design-system.umd.cjs"
    },
    "./style.css": "./src/style.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run build:lib",
    "build:lib": "vite build && tsc -p tsconfig.lib.json",
    "prepare": "npm run build:lib",
    "tokens:sync": "node scripts/export-tokens-from-figma.mjs",
    "tokens:check": "node scripts/check-token-drift.mjs",
    "storybook": "storybook dev --port 6006 --host 0.0.0.0",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "audit:phase4": "node scripts/audit-phase-4.mjs",
    "verify:storybook-static": "node scripts/verify-storybook-static.mjs",
    "verify:phase4": "node scripts/verify-phase-4.mjs",
    "verify:phase5": "node scripts/verify-phase-5.mjs",
    "verify:phase5:live": "node scripts/verify-phase-5-live.mjs",
    "test-storybook": "vitest --project=storybook"
  },
  "dependencies": {
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "chromatic": "^17.5.0",
    "playwright": "^1.61.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "10.4.6",
    "typescript": "5.7.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
